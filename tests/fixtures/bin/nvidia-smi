#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "nvlink" && "${2:-}" == "--status" ]]; then
  cat <<'EOF'
GPU 0:
  Link 0: Active
  Link 1: Inactive
EOF
  exit 0
fi

if [[ "${1:-}" == "nvlink" && "${2:-}" == "--errorcounters" ]]; then
  cat <<'EOF'
GPU 0:
  Link 0: Replay 2, Recovery 1, CRC FLIT 0, CRC DATA 0
  Link 1: Replay 0, Recovery 0, CRC FLIT 3, CRC DATA 1
EOF
  exit 0
fi

if [[ "${1:-}" == "nvlink" ]]; then
  exit 0
fi

case "${1:-}" in
--query-gpu=index,uuid,name,pci.bus_id,utilization.gpu,memory.used,memory.total,temperature.gpu,power.draw,pcie.link.gen.current,pcie.link.width.current,ecc.errors.volatile.total,bar1_memory.used,bar1_memory.total)
  cat <<'EOF'
0, GPU-123, Test GPU "A", 0000:01:00.0, 42, 1024, 8192, 70, 215.5, 5, 16, 0, 512, 1024
EOF
  exit 0
  ;;
--query-gpu=index,uuid,clocks_event_reasons.gpu_idle,clocks_event_reasons.applications_clocks_setting,clocks_event_reasons.sw_power_cap,clocks_event_reasons.hw_slowdown,clocks_event_reasons.hw_thermal_slowdown,clocks_event_reasons.hw_power_brake_slowdown,clocks_event_reasons.sync_boost,clocks_event_reasons.sw_thermal_slowdown,clocks_event_reasons.display_clocks_setting)
  cat <<'EOF'
0, GPU-123, Not Active, Not Active, Active, Not Active, Not Active, Not Active, Not Active, Not Active, Not Active
EOF
  exit 0
  ;;
--query-gpu=index,uuid,pstate)
  cat <<'EOF'
0, GPU-123, P2
EOF
  exit 0
  ;;
--query-gpu=index,uuid,power.limit,enforced.power.limit,clocks.sm,clocks.mem,clocks.max.sm,clocks.max.mem,fan.speed)
  cat <<'EOF'
0, GPU-123, 300.0, 285.0, 1410, 1593, 1770, 2000, 55 %
EOF
  exit 0
  ;;
--query-gpu=driver_version)
  cat <<'EOF'
550.54.15
EOF
  exit 0
  ;;
--query-gpu=cuda_version)
  cat <<'EOF'
12.4
EOF
  exit 0
  ;;
--query-gpu=index,uuid,memory.used,memory.total,memory.free,compute_mode,mig.mode.current,retired_pages.single_bit_ecc.count,retired_pages.double_bit.count,retired_pages.pending,remapped_rows.correctable,remapped_rows.uncorrectable,remapped_rows.pending)
  cat <<'EOF'
0, GPU-123, 10240, 16384, 4096, Default, Disabled, 2, 0, 1, 4, 0, 1
EOF
  exit 0
  ;;
--query-compute-apps=gpu_uuid,pid,used_gpu_memory,process_name)
  cat <<'EOF'
GPU-123, 4242, 6144, python
GPU-123, 4343, 1024, nccl-worker
EOF
  exit 0
  ;;
esac

cat <<'EOF'
0, GPU-123, Test GPU "A", 0000:01:00.0, 42, 1024, 8192, 70, 215.5, 5, 16, 0, 512, 1024
EOF
